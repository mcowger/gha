# YouTube sources are configured in src/sources.ts (not env vars)

# YouTube Data API v3 key (required) — https://console.cloud.google.com/apis/credentials
# Enable the "YouTube Data API v3" on the project the key belongs to.
YOUTUBE_API_KEY=

# GitHub token (recommended for higher rate limits)
GH_TOKEN=

# LLM configuration
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Output directory for generated HTML/JSON report files
OUTPUT_DIR=./output

# Path to state file tracking reviewed videos
STATE_FILE=./state/reviewed.json

# Port for the built-in HTTP server that serves the reports
PORT=8080

# Cron schedule for daemon mode (e.g. every 6 hours)
CRON_SCHEDULE=0 */6 * * *

# Concurrency settings (parallel processing)
# How many videos to process in parallel
VIDEO_CONCURRENCY=3
# How many projects to process (GitHub fetch + summarize) in parallel
PROJECT_CONCURRENCY=5
# How many LLM summarization calls to run in parallel
LLM_CONCURRENCY=3

# Notification Settings (Optional)
# Configure one or more to receive notifications when new repos are discovered:
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# NTFY_TOPIC=my-gha-topic
# NTFY_URL=https://ntfy.sh

